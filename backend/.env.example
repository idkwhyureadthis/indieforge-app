# --- HTTP ---
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_BASE_URL=http://localhost:5173          # base for YooKassa return_url
SWAGGER_ENABLED=true                         # serve Swagger UI at /swagger/index.html
TRENDING_INTERVAL=15m                        # how often to recompute trending scores

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://indieforge:indieforge@localhost:5432/indieforge?sslmode=disable

# --- Object storage (MinIO / S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=indieforge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_ENDPOINT=http://localhost:9000     # bare host the BROWSER can reach storage at — no bucket suffix

# --- YooKassa (test shop) ---
# Webhook URL is configured in the YooKassa dashboard (point it at /api/webhooks/yookassa via a tunnel).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Antivirus (ClamAV / clamd) ---
# Leave empty to disable scanning (uploads pass through untouched).
CLAMAV_ADDR=tcp://localhost:3310
