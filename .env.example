# Environment for `docker compose up` (root docker-compose.yml).
# Copy this file to `.env` in the project root, then fill in the
# REQUIRED section below. Everything else already has a working default
# baked into docker-compose.yml — uncomment a line only if you want to
# override that default.
#
# (Running the API or frontend directly, outside Docker? Use
#  backend/.env.example and frontend/.env.example instead — those point
#  at localhost services rather than docker-compose service names.)

# =============================================================================
# МОЖНО МЕНЯТЬ — у каждой переменной уже есть рабочее значение по умолчанию
# в docker-compose.yml. Раскомментируйте и поменяйте только то, что нужно.
# CAN BE CHANGED — every variable below already has a working default in
# docker-compose.yml. Uncomment and edit only what you want to override.
# =============================================================================

# --- Postgres ---
# POSTGRES_USER=indieforge
# POSTGRES_PASSWORD=indieforge
# POSTGRES_DB=indieforge
# POSTGRES_PORT=5432

# --- MinIO (S3-compatible object storage) ---
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# S3_REGION=us-east-1
# S3_BUCKET=indieforge

# --- ClamAV ---
# CLAMAV_PORT=3310

# --- API ---
# API_PORT=8080
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# APP_BASE_URL=http://localhost:5173
# SWAGGER_ENABLED=true
# TRENDING_INTERVAL=15m

# --- Frontend ---
# FRONTEND_PORT=5173
# VITE_API_URL is baked into the JS bundle at BUILD time (Vite inlines
# VITE_* vars), so changing it requires `docker compose up --build frontend`,
# not just a restart. Defaults to http://localhost:${API_PORT}/api.
# VITE_API_URL=http://localhost:8080/api

# =============================================================================
# ОБЯЗАТЕЛЬНО — у этих переменных НЕТ значения по умолчанию в docker-compose.yml.
# Если оставить их пустыми, стек всё равно запустится, но соответствующая
# функциональность не будет работать (см. комментарии). Ничего не подставится
# автоматически — задайте их сами.
# REQUIRED — these variables have NO default in docker-compose.yml. Leaving
# them blank still lets the stack start, but the related feature will not
# work (see comments below). Nothing gets auto-filled — you must set them.
# =============================================================================

# YooKassa test-shop credentials (https://yookassa.ru/my/shop-settings — switch
# to "Test mode" to get a test shop id + secret key). Without these, the API
# starts fine and the whole catalog/upload flow works, but POST /payments
# returns a clear "Payments are not configured" (503) instead of creating a
# real payment.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Only needed if you bring up the optional `ngrok` service
# (docker compose --profile tunnel up) to receive YooKassa's real webhook
# during manual end-to-end payment testing. Get a token at
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
